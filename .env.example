# Laval Digital - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Optional ─────────────────────────────────────────────────────
FLASK_SECRET_KEY=<generate-with: python3 -c "import secrets; print(secrets.token_hex(32))">

# ── Admin ─────────────────────────────────────────────────────────
ADMIN_USERNAME=<your-admin-username>
ADMIN_PASSWORD=<generate-a-strong-password>

# ── Optional ──────────────────────────────────────────────────────
DEV_MODE=false
DEV_API_KEY=
GOOGLE_MAPS_API_KEY=<your-maps-api-key>

# ── Backup ────────────────────────────────────────────────────────
BACKUP_ENCRYPTION_KEY=<optional-encryption-key>
BACKUP_OFFSITE_DEST=<optional-rsync-destination>

# ── Push Notifications ────────────────────────────────────────────
VAPID_PUBLIC_KEY=<auto-generated-if-not-set>
VAPID_PRIVATE_KEY=<auto-generated-if-not-set>
VAPID_SUBSCRIPTION=mailto:admin@lavaldigital.ca

# ── Error Monitoring ──────────────────────────────────────────────
SENTRY_DSN=<your-sentry-dsn-or-empty-to-disable>

# ── Credential Encryption Salt (OPTIONAL) ──────────────────────────
# By default, credential encryption keys are derived from FLASK_SECRET_KEY
# using HKDF with domain separation (recommended — no additional secret needed).
# Only set this if migrating from an older setup that requires the legacy salt.
# CREDENTIAL_SALT=<random-16-char-string>
